# Supabase — בלעדיו "הכנתי!"/מסע/העלאות עובדים בצד לקוח בלבד (בלי שמירה)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# פאנל אדמין (/admin) — בלעדיו הפאנל מושבת
ADMIN_TOKEN=CHOOSE_A_STRONG_RANDOM_SECRET

# תזכורות וואטסאפ דרך Flashy — בלעדיו טופס ההרשמה מושבת בשקט
FLASHY_API_KEY=YOUR_FLASHY_API_KEY
FLASHY_LIST=challenge-14
# אופציונלי — override ל-endpoint אם צריך:
# FLASHY_API_URL=https://flashyapp.com/api/v1.0/create_contact
